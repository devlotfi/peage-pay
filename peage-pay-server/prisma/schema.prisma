// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model AuthMethod {
  baseUser BaseUser @relation(fields: [userId], references: [id])

  id String @id @default(uuid())
  userId String @unique
  emailAuthMethod EmailAuthMethod?
  googleAuthMethod GoogleAuthMethod?
  phoneAuthMethod PhoneAuthMethod?
}

model EmailAuthMethod {
  authMethod AuthMethod @relation(fields: [authMethodId], references: [id])

  authMethodId String @id
  email String @unique
  passwordHash String
  verifiedAt DateTime?
}

model GoogleAuthMethod {
  authMethod AuthMethod @relation(fields: [authMethodId], references: [id])

  authMethodId String @id
  googleId String @unique
  email String @unique
}

model PhoneAuthMethod {
  authMethod AuthMethod @relation(fields: [authMethodId], references: [id])
  
  authMethodId String @id
  phoneNumber String @unique
}

model VerificationToken {
  baseUser BaseUser @relation(fields: [userId], references: [id])

  id String @id @default(uuid())
  userId String @unique
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model RefreshToken {
  baseUser BaseUser @relation(fields: [userId], references: [id])

  id String @id @default(uuid())
  userId String @unique
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model BaseUser {
  user User?
  authMethod AuthMethod?
  generalAdmin GeneralAdmin?
  humanRessourcesAdmin HumanRessourcesAdmin?
  moderator Moderator?
  tollAdmin TollAdmin?
  gateAdmin GateAdmin?
  verificationToken VerificationToken?
  refreshToken RefreshToken?
  
  id String @id @default(uuid())
  firstName String
  lastName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  baseUser BaseUser @relation(fields: [baseUserId], references: [id])

  baseUserId String @id
}

model GeneralAdmin {
  baseUser BaseUser @relation(fields: [baseUserId], references: [id])

  baseUserId String @id
}

model HumanRessourcesAdmin {
  baseUser BaseUser @relation(fields: [baseUserId], references: [id])

  baseUserId String @id
}

model Moderator {
  baseUser BaseUser @relation(fields: [baseUserId], references: [id])

  baseUserId String @id
}

model TollAdmin {
  baseUser BaseUser @relation(fields: [baseUserId], references: [id])

  baseUserId String @id
}

model GateAdmin {
  baseUser BaseUser @relation(fields: [baseUserId], references: [id])

  baseUserId String @id
}